# ══════════════════════════════════════════════════════════
# CHEF FINANCIERO — Variables de entorno
# Copia este archivo como .env.local para desarrollo local.
# En Vercel: configura en Project Settings → Environment Variables
# NUNCA subas .env.local al repositorio (está en .gitignore).
# ══════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────
# Encuéntralas en: supabase.com → Tu proyecto → Settings → API

# URL del proyecto (pública — safe para el frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon/pública (pública — safe para el frontend)
# Solo puede hacer lo que permiten las políticas RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── URL de la aplicación ─────────────────────────────────
# Desarrollo:  http://localhost:3002
# Producción:  https://tu-app.vercel.app  (o tu dominio personalizado)
NEXT_PUBLIC_APP_URL=http://localhost:3002
